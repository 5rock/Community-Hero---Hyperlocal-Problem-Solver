    "lint-staged": "^16.4.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
